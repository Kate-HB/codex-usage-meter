<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Meter"
        Width="320" Height="210"
        MinWidth="192" MinHeight="126"
        Topmost="True" ShowInTaskbar="False"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Border x:Name="DragSurface" Width="320" Height="210"
            Background="#F20D1114" BorderBrush="#FF2B343A" BorderThickness="1"
            CornerRadius="15" Padding="17,14,17,13">
        <Border.LayoutTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
        </Border.LayoutTransform>
        <Border.Effect>
            <DropShadowEffect Color="#CC000000" BlurRadius="18" ShadowDepth="5" Opacity="0.55" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="64" />
                <RowDefinition Height="55" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="8" Height="8" CornerRadius="4" Background="#FF63D99A"
                        VerticalAlignment="Center" Margin="0,0,9,0" />
                <TextBlock Grid.Column="1" Text="CODEX / LIVE METER" FontFamily="Bahnschrift"
                           FontSize="12" FontWeight="SemiBold" Foreground="#FFE5EAED"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="ZoomValue" Grid.Column="2" Text="100%" FontFamily="Consolas"
                           FontSize="10" Foreground="#FF7E8A91" VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,3,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="周额度剩余" FontFamily="Microsoft YaHei UI" FontSize="12"
                               Foreground="#FF9BA6AC" VerticalAlignment="Center" />
                    <TextBlock x:Name="WeeklyValue" Text="--" FontFamily="Bahnschrift"
                               FontSize="19" FontWeight="SemiBold" Foreground="#FF63D99A"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
                <Border Grid.Row="1" Height="7" CornerRadius="3.5" Background="#FF20282D"
                        BorderBrush="#FF303A40" BorderThickness="1" VerticalAlignment="Center">
                    <Grid Width="284" HorizontalAlignment="Left">
                        <Border x:Name="WeeklyBar" Width="0" HorizontalAlignment="Left"
                                CornerRadius="3" Background="#FF63D99A" />
                    </Grid>
                </Border>
                <TextBlock x:Name="ResetValue" Grid.Row="2" Text="重置 --"
                           FontFamily="Microsoft YaHei UI" FontSize="10" Foreground="#FF68757C"
                           VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,1,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="13" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="当前上下文剩余" FontFamily="Microsoft YaHei UI" FontSize="12"
                               Foreground="#FF9BA6AC" VerticalAlignment="Center" />
                    <TextBlock x:Name="ContextValue" Text="--" FontFamily="Bahnschrift"
                               FontSize="19" FontWeight="SemiBold" Foreground="#FF55A9F4"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
                <Border Grid.Row="1" Height="7" CornerRadius="3.5" Background="#FF20282D"
                        BorderBrush="#FF303A40" BorderThickness="1" VerticalAlignment="Center">
                    <Grid Width="284" HorizontalAlignment="Left">
                        <Border x:Name="ContextBar" Width="0" HorizontalAlignment="Left"
                                CornerRadius="3" Background="#FF55A9F4" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="5" Height="5" CornerRadius="2.5" Background="#FF63D99A"
                        VerticalAlignment="Center" Margin="0,0,7,0" />
                <TextBlock x:Name="FreshnessValue" Grid.Column="1" Text="等待 Codex 数据"
                           FontFamily="Microsoft YaHei UI" FontSize="10" Foreground="#FF7E8A91"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="CTRL + 滚轮缩放" FontFamily="Microsoft YaHei UI"
                           FontSize="9" Foreground="#FF4F5B61" VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Border>
</Window>
